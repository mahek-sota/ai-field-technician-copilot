# AI Field Technician Copilot - Environment Variables

# Google Gemini API Key (required for LLM diagnosis)
# Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (gemini-1.5-flash is cost-efficient for demos)
GEMINI_MODEL=gemini-1.5-flash

# Set to true to skip Gemini calls entirely (uses mock responses)
USE_MOCK_LLM=false

# Cache TTL in seconds (reduce Gemini calls by caching results)
CACHE_TTL_SECONDS=300

# Debug mode
DEBUG=false
